{
  "dashboard": {
    "id": null,
    "title": "System Performance",
    "tags": ["stock-monitor", "system", "performance"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-4h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "CPU Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "system_cpu_usage_percent",
            "legendFormat": "CPU Usage %"
          },
          {
            "expr": "app_cpu_usage",
            "legendFormat": "App CPU Usage %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "color": {
              "mode": "palette-classic"
            },
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Memory Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "system:memory_utilization:5m",
            "legendFormat": "System Memory %"
          },
          {
            "expr": "app_memory_usage / 1024 / 1024",
            "legendFormat": "App Memory MB"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 10
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "System Memory %"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "percent"
                },
                {
                  "id": "min",
                  "value": 0
                },
                {
                  "id": "max",
                  "value": 100
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "App Memory MB"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "decmbytes"
                }
              ]
            }
          ]
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Disk Usage",
        "type": "stat",
        "targets": [
          {
            "expr": "max(system_disk_usage_percent)",
            "legendFormat": "Max Disk Usage"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": 0
                },
                {
                  "color": "yellow",
                  "value": 80
                },
                {
                  "color": "red",
                  "value": 95
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 4,
        "title": "Network I/O",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(system_network_bytes_sent[5m])",
            "legendFormat": "Bytes Sent/sec"
          },
          {
            "expr": "rate(system_network_bytes_recv[5m])",
            "legendFormat": "Bytes Received/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "binBps",
            "custom": {
              "drawStyle": "line"
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 8
        }
      },
      {
        "id": 5,
        "title": "Process Count",
        "type": "stat",
        "targets": [
          {
            "expr": "system_process_count",
            "legendFormat": "Total Processes"
          },
          {
            "expr": "app_thread_count",
            "legendFormat": "App Threads"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 6,
        "title": "Load Average",
        "type": "timeseries",
        "targets": [
          {
            "expr": "system_load_1m",
            "legendFormat": "1m"
          },
          {
            "expr": "system_load_5m",
            "legendFormat": "5m"
          },
          {
            "expr": "system_load_15m",
            "legendFormat": "15m"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "line"
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 8
        }
      },
      {
        "id": 7,
        "title": "Database Performance",
        "type": "timeseries",
        "targets": [
          {
            "expr": "app_db_connections_active",
            "legendFormat": "Active Connections"
          },
          {
            "expr": "app_db_connections_idle", 
            "legendFormat": "Idle Connections"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "line"
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 12
        }
      },
      {
        "id": 8,
        "title": "Cache Performance",
        "type": "timeseries",
        "targets": [
          {
            "expr": "app_cache_hit_rate * 100",
            "legendFormat": "Hit Rate %"
          },
          {
            "expr": "app_cache_memory_usage / 1024 / 1024",
            "legendFormat": "Memory Usage MB"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line"
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Hit Rate %"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "percent"
                },
                {
                  "id": "min",
                  "value": 0
                },
                {
                  "id": "max", 
                  "value": 100
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Memory Usage MB"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "decmbytes"
                }
              ]
            }
          ]
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 12
        }
      },
      {
        "id": 9,
        "title": "API Performance",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(api_requests_total[5m]))",
            "legendFormat": "Requests/sec"
          },
          {
            "expr": "sum(rate(api_requests_total{status=~\"4..|5..\"}[5m])) / sum(rate(api_requests_total[5m])) * 100",
            "legendFormat": "Error Rate %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line"
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Error Rate %"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "percent"
                },
                {
                  "id": "color",
                  "value": {
                    "mode": "fixed",
                    "fixedColor": "red"
                  }
                }
              ]
            }
          ]
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 20
        }
      },
      {
        "id": 10,
        "title": "Response Time Distribution",
        "type": "heatmap",
        "targets": [
          {
            "expr": "sum(rate(api_request_duration_seconds_bucket[5m])) by (le)",
            "legendFormat": "{{ le }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "vis": false
              }
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 20
        }
      },
      {
        "id": 11,
        "title": "Top Resource Consumers",
        "type": "table",
        "targets": [
          {
            "expr": "topk(10, sum by (provider) (rate(api_requests_total[5m])))",
            "legendFormat": "{{ provider }}",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "displayMode": "table"
            }
          }
        },
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 0,
          "y": 28
        }
      },
      {
        "id": 12,
        "title": "Error Breakdown",
        "type": "table",
        "targets": [
          {
            "expr": "sum by (status, provider) (rate(api_requests_total{status=~\"4..|5..\"}[5m]))",
            "legendFormat": "{{ provider }} - {{ status }}",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "displayMode": "table"
            }
          }
        },
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 12,
          "y": 28
        }
      }
    ],
    "templating": {
      "list": []
    },
    "annotations": {
      "list": [
        {
          "name": "System Alerts",
          "datasource": "Prometheus",
          "expr": "ALERTS{alertname=~\".*System.*|.*CPU.*|.*Memory.*|.*Disk.*\", alertstate=\"firing\"}",
          "iconColor": "red"
        }
      ]
    }
  }
}