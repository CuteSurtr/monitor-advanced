{
  "dashboard": {
    "id": null,
    "title": "Portfolio Dashboard",
    "tags": ["stock-monitor", "portfolio"],
    "style": "dark",
    "timezone": "browser", 
    "refresh": "1m",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Portfolio Value Over Time",
        "type": "timeseries",
        "targets": [
          {
            "expr": "portfolio_total_value_usd{portfolio_id=\"$portfolio\"}",
            "legendFormat": "Total Value"
          },
          {
            "expr": "portfolio_total_value_usd{portfolio_id=\"$portfolio\"} offset 24h",
            "legendFormat": "Value 24h ago"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Daily P&L",
        "type": "stat",
        "targets": [
          {
            "expr": "business:portfolio_daily_return{portfolio_id=\"$portfolio\"}",
            "legendFormat": "Daily Return"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": -5
                },
                {
                  "color": "yellow",
                  "value": -1
                },
                {
                  "color": "green", 
                  "value": 0
                },
                {
                  "color": "blue",
                  "value": 5
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Portfolio Composition",
        "type": "piechart",
        "targets": [
          {
            "expr": "stock_position_value{portfolio_id=\"$portfolio\"}",
            "legendFormat": "{{ symbol }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "custom": {
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "vis": false
              }
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "Position Performance",
        "type": "table",
        "targets": [
          {
            "expr": "stock_position_value{portfolio_id=\"$portfolio\"}",
            "legendFormat": "{{ symbol }}",
            "format": "table"
          },
          {
            "expr": "stock_position_pnl{portfolio_id=\"$portfolio\"}",
            "legendFormat": "{{ symbol }}_pnl",
            "format": "table"
          },
          {
            "expr": "stock_position_pnl_percent{portfolio_id=\"$portfolio\"}",
            "legendFormat": "{{ symbol }}_pnl_pct",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "displayMode": "table"
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byRegexp",
                "options": ".*_pnl$"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "currencyUSD"
                },
                {
                  "id": "custom.displayMode",
                  "value": "color-background"
                },
                {
                  "id": "color",
                  "value": {
                    "mode": "continuous-GrYlRd"
                  }
                }
              ]
            },
            {
              "matcher": {
                "id": "byRegexp",
                "options": ".*_pnl_pct$"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "percent"
                }
              ]
            }
          ]
        },
        "gridPos": {
          "h": 10,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 5,
        "title": "Risk Metrics",
        "type": "timeseries",
        "targets": [
          {
            "expr": "portfolio_volatility{portfolio_id=\"$portfolio\"}",
            "legendFormat": "Volatility"
          },
          {
            "expr": "portfolio_sharpe_ratio{portfolio_id=\"$portfolio\"}",
            "legendFormat": "Sharpe Ratio"
          },
          {
            "expr": "portfolio_max_drawdown{portfolio_id=\"$portfolio\"}",
            "legendFormat": "Max Drawdown"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line"
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Volatility"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "percent"
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "Max Drawdown"
              },
              "properties": [
                {
                  "id": "unit", 
                  "value": "percent"
                }
              ]
            }
          ]
        },
        "gridPos": {
          "h": 10,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 6,
        "title": "Top Gainers/Losers",
        "type": "bargauge",
        "targets": [
          {
            "expr": "topk(5, stock_position_pnl_percent{portfolio_id=\"$portfolio\"})",
            "legendFormat": "{{ symbol }}"
          },
          {
            "expr": "bottomk(5, stock_position_pnl_percent{portfolio_id=\"$portfolio\"})",
            "legendFormat": "{{ symbol }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "color": {
              "mode": "continuous-GrYlRd"
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 18
        }
      },
      {
        "id": 7,
        "title": "Trading Activity",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(trade_executions_total{portfolio_id=\"$portfolio\"}[1h]))",
            "legendFormat": "Trades/hour"
          },
          {
            "expr": "sum(rate(trade_volume_usd{portfolio_id=\"$portfolio\"}[1h]))",
            "legendFormat": "Volume/hour"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "bars"
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Volume/hour"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "currencyUSD"
                }
              ]
            }
          ]
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 8,
          "y": 18
        }
      },
      {
        "id": 8,
        "title": "Portfolio Alerts",
        "type": "table",
        "targets": [
          {
            "expr": "ALERTS{alertname=~\".*Portfolio.*\", portfolio_id=\"$portfolio\"}",
            "legendFormat": "{{ alertname }}",
            "format": "table"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "displayMode": "table"
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 16,
          "y": 18
        }
      }
    ],
    "templating": {
      "list": [
        {
          "name": "portfolio",
          "type": "query",
          "query": "label_values(portfolio_total_value_usd, portfolio_id)",
          "refresh": 1,
          "includeAll": false,
          "multi": false
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Trades",
          "datasource": "Prometheus",
          "expr": "trade_executions_total{portfolio_id=\"$portfolio\"}",
          "iconColor": "blue"
        },
        {
          "name": "Portfolio Alerts",
          "datasource": "Prometheus",
          "expr": "ALERTS{alertname=~\".*Portfolio.*\", portfolio_id=\"$portfolio\", alertstate=\"firing\"}",
          "iconColor": "red"
        }
      ]
    }
  }
}