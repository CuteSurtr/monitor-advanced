          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  td.timestamp as time,\n  s.symbol,\n  td.last_price as value\nFROM market_data.tick_data td\nJOIN market_data.stocks s ON s.id = td.asset_id\nWHERE \n  td.asset_type = 'stock' AND\n  td.timestamp >= NOW() - INTERVAL '24 hours' AND\n  s.id IN (\n    SELECT s2.id \n    FROM market_data.stocks s2 \n    ORDER BY s2.market_cap DESC\n    LIMIT 30\n  )\nORDER BY td.timestamp",
          "refId": "A"
