          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_forex_prices AS (\n  SELECT DISTINCT ON (td.asset_id)\n    td.asset_id,\n    td.last_price as current_price,\n    td.volume,\n    td.timestamp,\n    LAG(td.last_price, 1) OVER (PARTITION BY td.asset_id ORDER BY td.timestamp) as prev_price\n  FROM market_data.tick_data td\n  WHERE td.asset_type = 'forex' AND td.timestamp >= NOW() - INTERVAL '24 hours'\n  ORDER BY td.asset_id, td.timestamp DESC\n)\nSELECT \n  fp.symbol,\n  CONCAT(fp.base_currency, '/', fp.quote_currency) as pair,\n  ROUND(lfp.current_price::numeric, 6) as current_rate,\n  ROUND(lfp.volume::numeric, 0) as volume,\n  ROUND(COALESCE(((lfp.current_price - lfp.prev_price) / lfp.prev_price * 100), 0)::numeric, 4) as change_percent,\n  CASE WHEN fp.is_major THEN 'Major' ELSE 'Minor' END as pair_type\nFROM latest_forex_prices lfp\nJOIN market_data.forex_pairs fp ON fp.id = lfp.asset_id\nORDER BY fp.is_major DESC, fp.id\nLIMIT 30",
