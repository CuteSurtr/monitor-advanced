          "rawSql": "WITH latest_commodity_prices AS (\n  SELECT DISTINCT ON (td.asset_id)\n    td.asset_id,\n    td.last_price as current_price,\n    td.volume,\n    td.timestamp,\n    LAG(td.last_price, 1) OVER (PARTITION BY td.asset_id ORDER BY td.timestamp) as prev_price\n  FROM market_data.tick_data td\n  WHERE td.asset_type = 'commodity' AND td.timestamp >= NOW() - INTERVAL '24 hours'\n  ORDER BY td.asset_id, td.timestamp DESC\n)\nSELECT \n  cm.symbol,\n  cm.name,\n  ROUND(lcp.current_price::numeric, 4) as current_price,\n  ROUND(lcp.volume::numeric, 0) as volume,\n  ROUND(COALESCE(((lcp.current_price - lcp.prev_price) / lcp.prev_price * 100), 0)::numeric, 2) as change_percent,\n  cm.asset_class\nFROM latest_commodity_prices lcp\nJOIN market_data.commodities cm ON cm.id = lcp.asset_id\nORDER BY cm.id\nLIMIT 30",
