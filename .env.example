# Stock Market Monitor - Environment Variables Template
# Copy this file to .env and fill in your actual values.
#
# Every variable below marked REQUIRED is enforced by docker-compose
# (via the ${VAR:?message} syntax) — the stack will refuse to start
# if any of them is missing or empty. This is intentional: it prevents
# accidentally shipping with a hardcoded weak default like `admin`.

# Database Configuration
POSTGRES_PASSWORD=your_postgres_password   # REQUIRED
POSTGRES_USER=stock_user
POSTGRES_DB=stock_monitor

# Redis Configuration
REDIS_PASSWORD=your_redis_password         # REQUIRED

# InfluxDB Configuration
INFLUXDB_TOKEN=your_influxdb_admin_token   # REQUIRED
INFLUXDB_PASSWORD=your_influxdb_password   # REQUIRED
INFLUXDB_ORG=stock_monitor
INFLUXDB_BUCKET=market_data
INFLUXDB_ADMIN_USER=admin
# Org ID used by a couple of populate_macro_data_bash.sh helpers only
INFLUXDB_ORG_ID=your_influxdb_org_id

# Grafana Configuration
GRAFANA_PASSWORD=your_grafana_admin_password  # REQUIRED
GRAFANA_ADMIN_USER=admin

# Desktop compose extras (docker-compose.desktop.yml only)
JUPYTER_TOKEN=your_jupyter_token            # REQUIRED when running desktop compose
PGADMIN_PASSWORD=your_pgadmin_password      # REQUIRED when running desktop compose
PGADMIN_EMAIL=admin@stockmonitor.com
FLOWER_PASSWORD=your_flower_password        # REQUIRED when running desktop compose
FLOWER_USER=admin
REDIS_COMMANDER_PASSWORD=your_redis_commander_password  # REQUIRED when running desktop compose
REDIS_COMMANDER_USER=admin

# API Keys - Financial Data
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
POLYGON_API_KEY=your_polygon_api_key
FINNHUB_API_KEY=your_finnhub_key
IEX_CLOUD_API_KEY=your_iex_cloud_key
QUANDL_API_KEY=your_quandl_key

# API Keys - News and Sentiment
NEWS_API_KEY=your_news_api_key

# API Keys - Cryptocurrency
COINGECKO_API_KEY=your_coingecko_api_key
COINMARKETCAP_API_KEY=your_coinmarketcap_key
BINANCE_API_KEY=your_binance_api_key

# API Keys - Forex and Currency
FIXER_API_KEY=your_fixer_api_key
EXCHANGERATE_API_KEY=your_exchangerate_api_key

# API Keys - Economic Data
FRED_API_KEY=your_fred_api_key
BEA_API_KEY=your_bea_api_key
EIA_API_KEY=your_eia_api_key
CENSUS_API_KEY=your_census_api_key
FINRA_API_KEY=your_finra_api_key

# Email Notifications
EMAIL_PASSWORD=your_email_app_password
EMAIL_USERNAME=your_email@gmail.com

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Application Security
SECRET_KEY=your_secret_key_for_auth

# Cloudflare Tunnel (Optional)
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# Redis Configuration (Optional)
REDIS_PASSWORD=your_redis_password

# Additional Configuration
CONFIG_PATH=/app/config/config.yaml
PYTHONPATH=/app:/app/src